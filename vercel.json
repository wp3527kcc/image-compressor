{
  "version": 2,
  "functions": {
    "api/compress.js": {
      "maxDuration": 60
    },
    "api/cleanup.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    {
      "source": "/login",
      "destination": "/login.html"
    },
    {
      "source": "/login/",
      "destination": "/login.html"
    },
    {
      "source": "/register",
      "destination": "/register.html"
    },
    {
      "source": "/register/",
      "destination": "/register.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cleanup",
      "schedule": "0 0 * * *"
    }
  ]
}
